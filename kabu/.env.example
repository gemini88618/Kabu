# .env.example

# Backend Configuration
ENVIRONMENT=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Data Fetching
YFINANCE_CACHE_ENABLED=true
YFINANCE_CACHE_TTL=3600

# Logging
LOG_LEVEL=info

# Backtest
BACKTEST_START_DATE=2022-01-01
BACKTEST_END_DATE=2024-12-31
BACKTEST_MIN_HISTORICAL_DAYS=260

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Optional: Render/Vercel Deployment
# RENDER_BACKEND_URL=https://your-backend-render.onrender.com
# VERCEL_FRONTEND_URL=https://your-frontend-vercel.vercel.app
